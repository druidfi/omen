        <!-- {"database":[{"host":"db","port":3306,"path":"drupal","username":"drupal","password":"drupal","scheme":"mysql","rel":"mysql","query":{"is_master":true}}]} -->
        <env name="PLATFORM_RELATIONSHIPS" value="eyJkYXRhYmFzZSI6W3siaG9zdCI6ImRiIiwicG9ydCI6MzMwNiwicGF0aCI6ImRydXBhbCIsInVzZXJuYW1lIjoiZHJ1cGFsIiwicGFzc3dvcmQiOiJkcnVwYWwiLCJzY2hlbWUiOiJteXNxbCIsInJlbCI6Im15c3FsIiwicXVlcnkiOnsiaXNfbWFzdGVyIjp0cnVlfX1dfQ=="/>
    </php>
    <testsuites>
        <testsuite name="drupal">
            <directory>../tests/Upsun</directory>
        </testsuite>
    </testsuites>
</phpunit>
