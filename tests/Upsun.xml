<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="../vendor/autoload.php" colors="true"
         beStrictAboutTestsThatDoNotTestAnything="true"
         beStrictAboutOutputDuringTests="true"
         beStrictAboutChangesToGlobalState="true"
         beStrictAboutCoversAnnotation="false"
         cacheResult="false">
    <php>
        <!-- Set error reporting to E_ALL. -->
        <ini name="error_reporting" value="32767"/>
        <!-- Do not limit the amount of memory tests take to run. -->
        <ini name="memory_limit" value="-1"/>
        <!-- Detectable ENV variables -->
        <env name="PLATFORM_APPLICATION" value="drupal"/>
        <env name="PLATFORM_ENVIRONMENT_TYPE" value="production"/>
        <env name="PLATFORM_PROJECT_ENTROPY" value="upsun-project-entropy-value"/>
        <env name="PLATFORM_TREE_ID" value="abc123treeid"/>
        <env name="PLATFORM_APP_DIR" value="/app"/>
        <!-- PLATFORM_ROUTES: base64-encoded JSON of routes -->
        <!-- redirect: https://www.main.drupal.upsun.app/ (excluded) -->
        <!-- upstream non-primary: https://secondary.drupal.upsun.app/ -> DRUPAL_ROUTES -->
        <!-- upstream primary: https://main.drupal.upsun.app/ -> DRUSH_OPTIONS_URI -->
        <!-- {"https://www.main.drupal.upsun.app/":{"primary":false,"type":"redirect"},"https://secondary.drupal.upsun.app/":{"primary":false,"type":"upstream","upstream":"drupal:http"},"https://main.drupal.upsun.app/":{"primary":true,"type":"upstream","upstream":"drupal:http"}} -->
        <env name="PLATFORM_ROUTES" value=""/>
